#. Plugin Name of the plugin
#: recover.php
msgid "Recover - Abandoned Cart Recovery for WooCommerce"
msgstr "Recuperar - Recuperación de carritos abandonados para WooCommerce"

#. Plugin URI of the plugin
#: recover.php
msgid "https://plogins.com/recover/"
msgstr "https://plogins.com/es/recover/"

#. Description of the plugin
#: recover.php
msgid ""
"Capture carts that are left behind and email customers a one-click link to "
"finish checkout."
msgstr ""
"Capture los carritos que se quedan atrás y envíe por correo electrónico a "
"los clientes un enlace de un solo clic para finalizar el pago."

#. Author of the plugin
#: recover.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: recover.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#. translators: 1: Required PHP version, 2: Current PHP version
#: recover.php:52
#, php-format
msgid "Recover requires PHP %1$s or higher. You are running PHP %2$s."
msgstr ""
"La recuperación requiere PHP %1$s o superior. Estás ejecutando PHP %2$s."

#: recover.php:68
msgid ""
"Recover - Abandoned Cart Recovery for WooCommerce requires WooCommerce to be"
" installed and activated."
msgstr ""
"Recuperar: la recuperación de carritos abandonados para WooCommerce requiere"
" que WooCommerce esté instalado y activado."

#. translators: 1: Required WC version, 2: Current WC version
#: recover.php:80
#, php-format
msgid ""
"Recover requires WooCommerce %1$s or higher. You are running WooCommerce "
"%2$s."
msgstr ""
"La recuperación requiere WooCommerce %1$s o superior. Estás ejecutando "
"WooCommerce %2$s."

#: src/Admin/CartsPage.php:36
msgid "Recover - Carts"
msgstr "Recuperar - Carros"

#: src/Admin/CartsPage.php:37
msgid "Recover Carts"
msgstr "Recuperar carros"

#: src/Admin/CartsPage.php:54 src/Service/CartTracker.php:137
msgid "Security check failed."
msgstr "El control de seguridad falló."

#: src/Admin/CartsPage.php:78 src/Admin/SettingsPage.php:41
msgid "Recover - Abandoned Carts"
msgstr "Recuperar - Carros abandonados"

#: src/Admin/CartsPage.php:81
msgid "Cart data for that email address has been erased."
msgstr ""
"Se borraron los datos del carrito para esa dirección de correo electrónico."

#: src/Admin/CartsPage.php:85 src/Admin/CartsPage.php:138
msgid "Pending"
msgstr "Pendiente"

#: src/Admin/CartsPage.php:86 src/Admin/CartsPage.php:139
msgid "Abandoned"
msgstr "abandonado"

#: src/Admin/CartsPage.php:87 src/Admin/CartsPage.php:140
msgid "Recovered"
msgstr "Recuperado"

#: src/Admin/CartsPage.php:88
msgid "Recovery rate"
msgstr "Tasa de recuperación"

#: src/Admin/CartsPage.php:92
msgid ""
"No carts recorded yet. Once shoppers add items and leave without checking "
"out, they will appear here."
msgstr ""
"Aún no se han registrado carros. Una vez que los compradores agreguen "
"artículos y se vayan sin pagar, aparecerán aquí."

#: src/Admin/CartsPage.php:97
msgid "Email"
msgstr "Correo electrónico"

#: src/Admin/CartsPage.php:98
msgid "Items"
msgstr "Artículos"

#: src/Admin/CartsPage.php:99
msgid "Value"
msgstr "Valor"

#: src/Admin/CartsPage.php:100
msgid "Status"
msgstr "Estado"

#: src/Admin/CartsPage.php:101
msgid "Emails"
msgstr "Correos electrónicos"

#: src/Admin/CartsPage.php:102
msgid "Last activity"
msgstr "Última actividad"

#: src/Admin/CartsPage.php:103
msgid "Privacy"
msgstr "Privacidad"

#: src/Admin/CartsPage.php:109
msgid "(no email yet)"
msgstr "(aún no hay correo electrónico)"

#: src/Admin/CartsPage.php:117
msgid "Erase all stored cart data for this email address?"
msgstr ""
"¿Borrar todos los datos del carrito almacenados para esta dirección de "
"correo electrónico?"

#: src/Admin/CartsPage.php:120
msgid "Erase"
msgstr "borrar"

#: src/Admin/SettingsPage.php:42
msgid "Recover"
msgstr "recuperar"

#: src/Admin/SettingsPage.php:75
msgid "General"
msgstr "General"

#: src/Admin/SettingsPage.php:77
msgid "Enable cart recovery"
msgstr "Habilitar la recuperación del carrito"

#: src/Admin/SettingsPage.php:77
msgid "Track abandoned carts and send recovery emails."
msgstr ""
"Realice un seguimiento de los carritos abandonados y envíe correos "
"electrónicos de recuperación."

#: src/Admin/SettingsPage.php:78
msgid "Capture guest carts"
msgstr "Capturar carritos de invitados"

#: src/Admin/SettingsPage.php:78
msgid "Record carts and emails from visitors who are not logged in."
msgstr ""
"Registre carritos y correos electrónicos de visitantes que no hayan iniciado"
" sesión."

#: src/Admin/SettingsPage.php:79
msgid "Require consent"
msgstr "Requerir consentimiento"

#: src/Admin/SettingsPage.php:79
msgid ""
"Only store a guest email after they tick a consent checkbox at checkout "
"(recommended for GDPR)."
msgstr ""
"Almacene el correo electrónico de un huésped solo después de que marque la "
"casilla de consentimiento al finalizar la compra (recomendado para GDPR)."

#: src/Admin/SettingsPage.php:82
msgid "Consent checkbox label"
msgstr "Etiqueta de casilla de verificación de consentimiento"

#: src/Admin/SettingsPage.php:83
msgid ""
"Wording the shopper sees next to the consent checkbox at checkout. Applies "
"only when \"Require consent\" is on."
msgstr ""
"Texto que el comprador ve junto a la casilla de consentimiento al finalizar "
"la compra. Se aplica solo cuando \"Requerir consentimiento\" está activado."

#: src/Admin/SettingsPage.php:91
msgid "Timing"
msgstr "Sincronización"

#: src/Admin/SettingsPage.php:93
msgid ""
"Control how long to wait before a cart is considered abandoned and emails go"
" out. The recovery worker runs hourly via wp-cron."
msgstr ""
"Controle cuánto tiempo esperar antes de que un carrito se considere "
"abandonado y se envíen correos electrónicos. El trabajador de recuperación "
"se ejecuta cada hora a través de wp-cron."

#: src/Admin/SettingsPage.php:98
msgid "Mark abandoned after (minutes)"
msgstr "Marcar como abandonado tras (minutos)"

#: src/Admin/SettingsPage.php:98
msgid "Minutes of inactivity before a pending cart is flagged as abandoned."
msgstr ""
"Minutos de inactividad antes de que un carrito pendiente se marque como "
"abandonado."

#: src/Admin/SettingsPage.php:99
msgid "Email delay (minutes)"
msgstr "Retraso del correo electrónico (minutos)"

#: src/Admin/SettingsPage.php:99
msgid "Minutes to wait after abandonment before sending the recovery email."
msgstr ""
"Minutos de espera tras el abandono antes de enviar el email de recuperación."

#: src/Admin/SettingsPage.php:104
msgid "Recovery email"
msgstr "Correo electrónico de recuperación"

#: src/Admin/SettingsPage.php:106
msgid ""
"Customise the recovery email. Leave any field blank to use the built-in "
"default shown as the placeholder. Emails are sent through your own site "
"mailer; no data leaves your store."
msgstr ""
"Personaliza el correo electrónico de recuperación. Deje cualquier campo en "
"blanco para utilizar el valor predeterminado integrado que se muestra como "
"marcador de posición. Los correos electrónicos se envían a través del correo"
" de tu propio sitio; ningún dato sale de tu tienda."

#: src/Admin/SettingsPage.php:113
msgid "Subject"
msgstr "Asunto"

#: src/Admin/SettingsPage.php:114
msgid ""
"Inbox subject line. Keep it short and specific so it survives a crowded "
"inbox."
msgstr ""
"Línea de asunto de la bandeja de entrada. Sea breve y específico para que "
"sobreviva a una bandeja de entrada abarrotada."

#: src/Admin/SettingsPage.php:120
msgid "Heading"
msgstr "Título"

#: src/Admin/SettingsPage.php:121
msgid "The large heading at the top of the email body, above your message."
msgstr ""
"El encabezado grande en la parte superior del cuerpo del correo electrónico,"
" encima de su mensaje."

#: src/Admin/SettingsPage.php:127
msgid "Body text"
msgstr "Texto del cuerpo"

#: src/Admin/SettingsPage.php:128
msgid ""
"The message shown above the recovery button. Plain text only; write what "
"nudges the shopper back."
msgstr ""
"El mensaje que se muestra encima del botón de recuperación. Sólo texto sin "
"formato; escriba lo que haga retroceder al comprador."

#: src/Admin/SettingsPage.php:134
msgid "Button label"
msgstr "Etiqueta del botón"

#: src/Admin/SettingsPage.php:135
msgid "Text on the button that returns the shopper to their saved cart."
msgstr "Texto en el botón que devuelve al comprador a su carrito guardado."

#: src/Admin/SettingsPage.php:154
msgid ""
"Cart recovery is currently disabled. Enable it below to start tracking "
"abandoned carts."
msgstr ""
"La recuperación del carrito está actualmente deshabilitada. Habilítelo a "
"continuación para comenzar a rastrear carritos abandonados."

#. translators: %s: human-readable time difference
#: src/Admin/SettingsPage.php:163
#, php-format
msgid "Next recovery run: in %s."
msgstr "Próxima ejecución de recuperación: en %s."

#: src/Admin/SettingsPage.php:167
msgid ""
"The recovery worker is not scheduled. Re-activate the plugin to restore it."
msgstr ""
"El trabajador de recuperación no está programado. Vuelva a activar el "
"complemento para restaurarlo."

#: src/Admin/SettingsPage.php:170
msgid "View abandoned carts →"
msgstr "Ver carritos abandonados →"

#: src/Service/CartTracker.php:142
msgid "Provide a valid email address."
msgstr "Proporcione una dirección de correo electrónico válida."

#: src/Settings.php:84
msgid "Email me a link to recover my cart if I do not complete my order."
msgstr ""
"Envíeme por correo electrónico un enlace para recuperar mi carrito si no "
"completo mi pedido."

#: src/Settings.php:91
msgid "You left something in your cart"
msgstr "Dejaste algo en tu carrito"

#: src/Settings.php:98
msgid "Still thinking it over?"
msgstr "¿Aún lo estás pensando?"

#: src/Settings.php:107
msgid ""
"We saved your cart for you. Click the button below to pick up right where "
"you left off."
msgstr ""
"Guardamos su carrito para ti. Haga clic en el botón de abajo para continuar "
"justo donde lo dejó."

#: src/Settings.php:114
msgid "Complete my order"
msgstr "Completar mi pedido"

#: templates/emails/recovery.php:76
msgid "We left the light on, your cart is still here."
msgstr "Dejamos la luz encendida, tu carrito sigue aquí."

#: templates/emails/recovery.php:90
msgid "The link picks up right where you left off."
msgstr "El enlace continúa justo donde lo dejaste."

#. translators: %s: site name
#: templates/emails/recovery.php:100
#, php-format
msgid ""
"This message was sent by %s because a cart was left behind. If this was not "
"you, you can safely ignore this email."
msgstr ""
"Este mensaje fue enviado por %s porque se dejó un carrito. Si no eres tú, "
"puedes ignorar este correo electrónico con seguridad."
